@model AutosWeb.Models.AutoViewModel
@using AutosWeb.Models

<div asp-validation-summary="ModelOnly" class="notification is-danger is-light" role="alert"></div>

<input type="hidden" asp-for="Id" />

<div class="columns is-multiline">
    <div class="field column is-half">
        <label class="label" asp-for="Marca"></label>
        <div class="control">
            <input class="input" asp-for="Marca" maxlength="50" required aria-required="true" />
        </div>
        <p class="help is-danger" asp-validation-for="Marca"></p>
    </div>

    <div class="field column is-half">
        <label class="label" asp-for="Modelo"></label>
        <div class="control">
            <input class="input" asp-for="Modelo" maxlength="50" required aria-required="true" />
        </div>
        <p class="help is-danger" asp-validation-for="Modelo"></p>
    </div>

    <div class="field column is-one-third">
        <label class="label" asp-for="Anio"></label>
        <div class="control">
            <input class="input" type="number" asp-for="Anio" min="1900" max="2100" required />
        </div>
        <p class="help is-danger" asp-validation-for="Anio"></p>
    </div>

    <div class="field column is-one-third">
        <label class="label" asp-for="TipoAuto"></label>
        <div class="control">
            <div class="select is-fullwidth">
                <select asp-for="TipoAuto" required>
                    <option value="">-- Seleccionar --</option>
                    @foreach (var tipo in TiposAuto.Opciones)
                    {
                        <option value="@tipo">@tipo</option>
                    }
                </select>
            </div>
        </div>
        <p class="help is-danger" asp-validation-for="TipoAuto"></p>
    </div>

    <div class="field column is-one-third">
        <label class="label" asp-for="CantidadAsientos"></label>
        <div class="control">
            <input class="input" type="number" asp-for="CantidadAsientos" min="1" max="20" required />
        </div>
        <p class="help is-danger" asp-validation-for="CantidadAsientos"></p>
    </div>

    <div class="field column is-half">
        <label class="label" asp-for="Color"></label>
        <div class="control">
            <input class="input" asp-for="Color" maxlength="30" required />
        </div>
        <p class="help is-danger" asp-validation-for="Color"></p>
    </div>

    <div class="field column is-half">
        <label class="label" asp-for="Precio"></label>
        <div class="control">
            <input class="input" type="number" step="0.01" min="0" asp-for="Precio" required />
        </div>
        <p class="help is-danger" asp-validation-for="Precio"></p>
    </div>

    <div class="field column is-full">
        <label class="checkbox">
            <input type="checkbox" asp-for="Activo" />
            Activo
        </label>
    </div>
</div>

<div class="field is-grouped">
    <div class="control">
        <button type="submit" class="button is-primary">Guardar</button>
    </div>
    <div class="control">
        <a class="button is-light" asp-action="Index">Cancelar</a>
    </div>
</div>
